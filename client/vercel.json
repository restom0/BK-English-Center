{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/proxy?path=$1" },
    { "source": "/", "destination": "/pages/public/home/index.html" },
    { "source": "/home", "destination": "/pages/public/home/index.html" },
    { "source": "/courses", "destination": "/pages/public/courses/index.html" },
    { "source": "/course-detail", "destination": "/pages/public/courses-detail/index.html" },
    { "source": "/contact", "destination": "/pages/public/contact/index.html" },
    { "source": "/login", "destination": "/pages/auth/login/index.html" },
    { "source": "/signup", "destination": "/pages/auth/signup/index.html" },
    { "source": "/forgot-password", "destination": "/pages/auth/forgot-password/index.html" },
    { "source": "/choose-actor", "destination": "/pages/auth/choose-actor/index.html" },
    { "source": "/my-courses", "destination": "/pages/public/my-courses/index.html" },
    { "source": "/my-page", "destination": "/pages/public/my-page/index.html" },
    { "source": "/admin", "destination": "/pages/admin/dashboard/index.html" },
    { "source": "/staff", "destination": "/pages/staff/dashboard/index.html" },
    { "source": "/stat-financial", "destination": "/pages/staff/stat-financial/index.html" },
    { "source": "/stat-access", "destination": "/pages/staff/stat-access/index.html" },
    { "source": "/stat-class", "destination": "/pages/staff/stat-class/index.html" },
    { "source": "/manage-courses", "destination": "/pages/staff/manage-courses/index.html" },
    { "source": "/staff-info", "destination": "/pages/staff/profile/index.html" },
    { "source": "/staff-attendance", "destination": "/pages/staff/attendance/index.html" },
    { "source": "/staff-pay", "destination": "/pages/staff/payment/index.html" },
    { "source": "/student-info", "destination": "/pages/student/profile/index.html" },
    { "source": "/student-attendance", "destination": "/pages/student/attendance/index.html" },
    { "source": "/student-marks", "destination": "/pages/student/marks/index.html" },
    { "source": "/student-pay", "destination": "/pages/student/payment/index.html" },
    { "source": "/teacher-info", "destination": "/pages/teacher/profile/index.html" },
    { "source": "/teacher-attendance", "destination": "/pages/teacher/attendance/index.html" },
    { "source": "/teacher-rate", "destination": "/pages/teacher/rating/index.html" },
    { "source": "/teacher-pay", "destination": "/pages/teacher/payment/index.html" },
    { "source": "/teacher-files", "destination": "/pages/teacher/files/index.html" }
  ]
}
