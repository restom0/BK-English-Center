{
  "name": "dacnpm-client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css":   "sass styles/main.scss styles/main.css --style=compressed --no-source-map",
    "watch:css":   "sass styles/main.scss styles/main.css --watch --no-source-map",
    "build:css:dev":"sass styles/main.scss styles/main.css --style=expanded",
    "lint:css":    "sass --dry-run styles/main.scss styles/main.css",
    "build:icons": "node scripts/extract-icons.cjs",
    "lint":        "eslint js/ utils/ --ext .js",
    "lint:fix":    "eslint js/ utils/ --ext .js --fix",
    "format":      "prettier --write 'js/**/*.js' 'utils/*.js' 'config.js'",
    "format:check":"prettier --check 'js/**/*.js' 'utils/*.js' 'config.js'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.99.0"
  },
  "dependencies": {
    "developer-icons": "^7.0.1"
  }
}
