# Normalize all text files to LF in the repo and working tree.
# Keeps Prettier (endOfLine: lf) green on the Linux CI runners and
# stops the CRLF/LF churn from Windows checkouts.
* text=auto eol=lf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
