# =============================================================
# BK English Center — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (Prisma) ───────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://bkec:changeme@localhost:5432/bkec?schema=public

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars
JWT_EXPIRES_IN=28800

# ── Email (Gmail SMTP + App Password) ────────────────────────
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5500

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── Cache TTL (seconds) ───────────────────────────────────────
CACHE_TTL=300

# =============================================================
# Docker Compose additional vars (used by docker-compose.yml)
# =============================================================
POSTGRES_USER=bkec
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bkec
