{
  "name": "dacnpm_server",
  "version": "2.0.0",
  "description": "BK English Center — Express REST API",
  "main": "index.js",
  "scripts": {
    "start":       "node index.js",
    "dev":         "nodemon index.js",
    "db:generate": "prisma generate",
    "db:migrate":  "prisma migrate deploy",
    "db:seed":     "node prisma/seed.js",
    "db:studio":   "prisma studio",
    "lint":        "prettier --check 'src/**/*.{js,json}' 'routes/**/*.js' 'index.js'",
    "lint:fix":    "prettier --write 'src/**/*.{js,json}' 'routes/**/*.js' 'index.js'",
    "eslint":      "eslint src/ routes/ index.js",
    "eslint:fix":  "eslint src/ routes/ index.js --fix",
    "format":      "prettier --write 'src/**/*.js' 'routes/**/*.js' 'index.js'",
    "format:check":"prettier --check 'src/**/*.js' 'routes/**/*.js' 'index.js'",
    "test":        "echo \"Error: no test specified\" && exit 1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "author": "",
  "license": "ISC",
  "keywords": [],
  "dependencies": {
    "@prisma/client":      "^5.14.0",
    "bcrypt":              "^6.0.0",
    "cookie-parser":       "^1.4.6",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "express-rate-limit":  "^7.3.1",
    "http-errors":         "^2.0.0",
    "ioredis":             "^5.3.2",
    "jsonwebtoken":        "^9.0.3",
    "morgan":              "^1.10.0",
    "mysql2":              "^3.9.7",
    "nodemailer":          "^6.9.13",
    "swagger-jsdoc":       "^6.2.8",
    "swagger-ui-express":  "^5.0.1"
  },
  "devDependencies": {
    "husky":     "^9.0.11",
    "lint-staged":"^15.2.5",
    "nodemon":   "^3.1.4",
    "prettier":  "^3.3.2",
    "prisma":    "^5.14.0"
  }
}
