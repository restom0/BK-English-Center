{
  "name": "dacnpm_server",
  "version": "2.0.0",
  "description": "BK English Center — Express REST API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "lint": "prettier --check \"src/**/*.{js,json}\" \"routes/**/*.js\" \"test/**/*.js\" \"scripts/**/*.js\" \"bruno/**/*.yml\" \"index.js\"",
    "lint:fix": "prettier --write \"src/**/*.{js,json}\" \"routes/**/*.js\" \"test/**/*.js\" \"scripts/**/*.js\" \"bruno/**/*.yml\" \"index.js\"",
    "eslint": "eslint --quiet src/ routes/ test/ scripts/ index.js",
    "eslint:fix": "eslint src/ routes/ test/ scripts/ index.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"routes/**/*.js\" \"test/**/*.js\" \"scripts/**/*.js\" \"bruno/**/*.yml\" \"index.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"routes/**/*.js\" \"test/**/*.js\" \"scripts/**/*.js\" \"bruno/**/*.yml\" \"index.js\"",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand test/unit",
    "test:api": "jest --runInBand test/api",
    "test:integration": "jest --runInBand test/integration",
    "test:bruno": "node scripts/run-bruno-api-tests.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --runInBand",
    "quality": "npm run format:check && npm run eslint && npm run test:cov",
    "quality:ci": "npm run quality && npm run test:bruno"
  },
  "author": "",
  "license": "ISC",
  "keywords": [],
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "http-errors": "^2.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.23.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@usebruno/cli": "^3.4.2",
    "eslint": "^10.7.0",
    "husky": "^9.0.11",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  }
}
